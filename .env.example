# ============================================================
# Aplikasi Manajemen Pesantren — Production Environment
# ============================================================
# Copy file ini ke .env dan sesuaikan dengan konfigurasi Anda
# cp .env.example .env

# ── Domain ───────────────────────────────────────────────────────────────
# Domain utama untuk akses aplikasi (tanpa https://)
DOMAIN=pesantren.example.com
EMAIL=admin@example.com

# ── Database ─────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=pesantren
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ── JWT Secrets ──────────────────────────────────────────────────────────
# Generate dengan: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_LONG_RANDOM_SECRET_64_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── WhatsApp Provider ────────────────────────────────────────────────────
# Options: fonnte, twilio, wablas
WA_PROVIDER=fonnte
WA_API_KEY=your_wa_api_key_here

# ── File Storage ─────────────────────────────────────────────────────────
# Options: local, s3
STORAGE_DRIVER=local

# AWS S3 (jika STORAGE_DRIVER=s3)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ── License ──────────────────────────────────────────────────────────────
LICENSE_SERVER_URL=https://license.pesantren-app.com
LICENSE_KEY=your_license_key_here

# ── Monitoring (optional) ────────────────────────────────────────────────
SENTRY_DSN=

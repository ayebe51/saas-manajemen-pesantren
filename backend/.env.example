# ============================================================
# Aplikasi Manajemen Pesantren Enterprise - Environment Config
# ============================================================

# App
PORT=3000
NODE_ENV=development
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pesantren?schema=public"
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pesantren

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_in_production
JWT_REFRESH_EXPIRATION=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass

# WhatsApp Provider
# Options: fonnte, twilio, wablas, custom
WA_PROVIDER=fonnte
WA_API_KEY=your_wa_api_key_here
WA_SENDER_NUMBER=628xxxxxxxxxx

# Fonnte (if WA_PROVIDER=fonnte)
FONNTE_TOKEN=your_fonnte_token_here

# Twilio (if WA_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# License Server
LICENSE_SERVER_URL=https://license.pesantren-app.com
LICENSE_KEY=your_license_key_here
LICENSE_ENCRYPTION_KEY=change_this_to_a_long_random_secret_for_license_encryption

# File Storage
# Options: local, s3
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# AWS S3 (if STORAGE_DRIVER=s3)
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=pesantren-app

# Backup
BACKUP_DIR=./backup
BACKUP_RETENTION_DAYS=30

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
LOGIN_THROTTLE_LIMIT=10
LOGIN_LOCKOUT_MINUTES=15

# Sentry (optional)
SENTRY_DSN=

# Bcrypt
BCRYPT_ROUNDS=12

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String                 @id @default(uuid())
  name                  String
  address               String?
  phone                 String?
  adminUserId           String?
  timezone              String                 @default("Asia/Jakarta")
  plan                  String                 @default("BASIC")
  billingContact        String?
  status                String                 @default("ACTIVE")
  settings              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  scannerPin            String?                @unique
  academicScheds        AcademicSchedule[]
  attendances           Attendance[]
  auditLogs             AuditLog[]
  buildings             Building[]
  catatanHarian         CatatanHarian[]
  employees             Employee[]
  grades                Grade[]
  healthRecords         HealthRecord[]
  inventoryTransactions InventoryTransaction[]
  invoices              Invoice[]
  inventoryItems        Item[]
  izin                  Izin[]
  kunjungan             Kunjungan[]
  maintenanceTickets    MaintenanceTicket[]
  mutabaah              Mutabaah[]
  notifications         Notification[]
  payrolls              Payroll[]
  pelanggaran           Pelanggaran[]
  pembinaan             Pembinaan[]
  pengumuman            Pengumuman[]
  points                Point[]
  ppdbDocuments         PpdbDocument[]
  ppdbExams             PpdbExam[]
  ppdbRegistrations     PpdbRegistration[]
  purchaseOrders        PurchaseOrder[]
  roomAssignments       RoomAssignment[]
  rooms                 Room[]
  santri                Santri[]
  suppliers             Supplier[]
  tahfidz               Tahfidz[]
  users                 User[]
  wali                  Wali[]
  wallets               Wallet[]
  webhookEvents         WebhookEvent[]
  presensiSessions      PresensiSession[]
  perizinan             Perizinan[]            @relation("PerizinanToTenant")

  @@map("tenants")
}

model User {
  id            String         @id @default(uuid())
  tenantId      String?
  email         String         @unique
  passwordHash  String
  role          String         @default("PENGURUS")
  roleId        String?
  name          String
  phone         String?
  isActive      Boolean        @default(true)
  lastLogin     DateTime?
  fcmTokens     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  auditLogs     AuditLog[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])
  role_ref      Role?          @relation(fields: [roleId], references: [id])
  perizinanApproved  Perizinan[]    @relation("PerizinanApprover")
  perizinanCreated   Perizinan[]    @relation("PerizinanCreator")
  pelanggaranDibuat  Pelanggaran[]  @relation("PelanggaranCreatedBy")
  rewardDibuat       RewardPoin[]   @relation("RewardPoinCreatedBy")

  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  token       String    @unique
  tokenHash   String?   @unique
  expiresAt   DateTime
  revoked     Boolean   @default(false)
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Santri {
  id             String          @id @default(uuid())
  tenantId       String
  nis            String?         @unique  // Nomor Induk Santri — unique per pesantren
  nisn           String?
  namaLengkap    String?
  namaPanggilan  String?
  name           String
  gender         String
  jenisKelamin   String?
  dob            DateTime?
  tanggalLahir   DateTime?
  tempatLahir    String?
  kelas          String?
  kelasId        String?
  room           String?
  contact        String?
  noHp           String?
  address        String?
  alamat         String?
  photo          String?
  fotoUrl        String?
  tanggalMasuk   DateTime?
  tanggalKeluar  DateTime?
  status         String          @default("AKTIF")  // AKTIF, ALUMNI, KELUAR
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?       // soft delete
  attendances    Attendance[]    @relation("AttendanceToSantri")
  catatanHarian  CatatanHarian[]
  grades         Grade[]         @relation("GradeToSantri")
  healthRecords  HealthRecord[]
  invoices       Invoice[]
  izin           Izin[]
  kunjungan      Kunjungan[]
  medications    Medication[]
  mutabaah       Mutabaah[]      @relation("MutabaahToSantri")
  pelanggaran    Pelanggaran[]
  pembinaan      Pembinaan[]
  points         Point[]         @relation("PointToSantri")
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  walis          SantriWali[]
  tahfidz        Tahfidz[]       @relation("TahfidzToSantri")
  wallet         Wallet?         @relation("WalletToSantri")
  presensiRecords PresensiRecord[] @relation("PresensiRecordToSantri")
  perizinan       Perizinan[]      @relation("PerizinanToSantri")
  rewardPoin      RewardPoin[]

  @@index([tenantId])
  @@index([nis])
  @@index([deletedAt])
  @@map("santri")
}

model Wali {
  id           String       @id @default(uuid())
  tenantId     String
  userId       String?      // linked User account if wali has portal access
  namaLengkap  String?
  name         String
  hubungan     String?
  relation     String
  noHp         String?
  phone        String
  email        String?
  address      String?
  alamat       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  santris      SantriWali[]
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("wali")
}

model SantriWali {
  santriId  String
  waliId    String
  isPrimary Boolean @default(false)
  santri    Santri  @relation(fields: [santriId], references: [id], onDelete: Cascade)
  wali      Wali    @relation(fields: [waliId], references: [id], onDelete: Cascade)

  @@id([santriId, waliId])
  @@map("santri_wali")
}

model Izin {
  id          String    @id @default(uuid())
  tenantId    String
  santriId    String
  type        String
  reason      String
  startAt     DateTime
  endAt       DateTime
  status      String    @default("PENDING")
  requestedBy String
  approvedBy  String?
  approvedAt  DateTime?
  qrCodeData  String?   @unique
  checkoutAt  DateTime?
  checkoutBy  String?
  checkinAt   DateTime?
  checkinBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  santri      Santri    @relation(fields: [santriId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("izin")
}

model CatatanHarian {
  id          String   @id @default(uuid())
  tenantId    String
  santriId    String
  authorId    String
  date        DateTime @default(now())
  content     String
  category    String
  attachments String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  santri      Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("catatan_harian")
}

model Pengumuman {
  id          String    @id @default(uuid())
  tenantId    String
  title       String
  content     String
  audience    String
  pinnedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("pengumuman")
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  santriId      String
  invoiceNumber String        @unique  // Format: INV-YYYYMM-XXXXX — Requirement 11.1
  tipe          String        @default("SPP")  // SPP, DAFTAR_ULANG, LAINNYA
  jumlah        Decimal       @db.Decimal(15, 2)
  amountDue     Float         @default(0)  // kept for backward compat
  dueDate       DateTime
  status        String        @default("PENDING")
  // State machine: PENDING → PAID/EXPIRED/CANCELLED, PAID → REFUNDED — Requirement 11.2
  paidAt        DateTime?
  paidBy        String?       // userId of petugas who confirmed
  keterangan    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  lines         InvoiceLine[]
  santri        Santri        @relation(fields: [santriId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@index([tenantId])
  @@index([santriId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  amount      Float
  type        String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model Payment {
  id             String    @id @default(uuid())
  invoiceId      String
  method         String
  amount         Float
  status         String    @default("PENDING")
  transactionRef String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model Pelanggaran {
  id               String           @id @default(uuid())
  tenantId         String
  santriId         String
  kategoriId       String?
  recordedBy       String
  category         String
  tingkatKeparahan TingkatKeparahan?
  severity         Int
  poin             Int              @default(0)
  points           Int              @default(0)
  keterangan       String?
  description      String
  serverTimestamp  DateTime         @default(now())
  date             DateTime         @default(now())
  resolved         Boolean          @default(false)
  createdBy        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  santri           Santri           @relation(fields: [santriId], references: [id], onDelete: Cascade)
  kategori         KategoriPelanggaran? @relation(fields: [kategoriId], references: [id])
  creator          User?            @relation("PelanggaranCreatedBy", fields: [createdBy], references: [id])
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("pelanggaran")
}

model Pembinaan {
  id         String   @id @default(uuid())
  tenantId   String
  santriId   String
  plan       String
  targetDate DateTime
  status     String   @default("ONGOING")
  assignedTo String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  santri     Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("pembinaan")
}

model Kunjungan {
  id           String   @id @default(uuid())
  tenantId     String
  santriId     String
  scheduledAt  DateTime
  slot         String
  visitorLimit Int      @default(2)
  status       String   @default("SCHEDULED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  santri       Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tamu         Tamu[]

  @@index([tenantId])
  @@index([santriId])
  @@map("kunjungan")
}

model Tamu {
  id          String    @id @default(uuid())
  kunjunganId String
  name        String
  phone       String?
  idNumber    String?
  checkinAt   DateTime?
  createdAt   DateTime  @default(now())
  kunjungan   Kunjungan @relation(fields: [kunjunganId], references: [id], onDelete: Cascade)

  @@index([kunjunganId])
  @@map("tamu")
}

model HealthRecord {
  id          String   @id @default(uuid())
  tenantId    String
  santriId    String
  recordedBy  String
  symptoms    String
  diagnosis   String?
  actionTaken String?
  referred    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  santri      Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("health_records")
}

model Medication {
  id           String    @id @default(uuid())
  santriId     String
  medicineName String
  dose         String
  schedule     String
  givenBy      String?
  givenAt      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  santri       Santri    @relation(fields: [santriId], references: [id], onDelete: Cascade)

  @@index([santriId])
  @@map("medications")
}

model AuditLog {
  id              String   @id @default(uuid())
  tenantId        String?
  userId          String?
  action          String
  entity          String
  entityId        String
  oldValue        String?
  newValue        String?
  ip              String?
  createdAt       DateTime @default(now())
  modul           String?
  entitasTipe     String?
  nilaiSebelum    Json?
  nilaiSesudah    Json?
  serverTimestamp DateTime @default(now())
  tenant          Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@map("notifications")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  tenantId    String?
  eventType   String
  payload     String
  status      String    @default("PENDING")
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("webhook_events")
}

model Tahfidz {
  id         String   @id @default(uuid())
  tenantId   String
  santriId   String
  surah      String
  ayat       String?
  type       String   @default("ZIYADAH")
  grade      String?
  notes      String?
  recordedBy String
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  santri     Santri   @relation("TahfidzToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("tahfidz")
}

model Mutabaah {
  id          String   @id @default(uuid())
  tenantId    String
  santriId    String
  date        DateTime @default(now())
  sholatWajib Boolean  @default(true)
  tahajud     Boolean  @default(false)
  dhuha       Boolean  @default(false)
  puasaSunnah Boolean  @default(false)
  bacaQuran   Boolean  @default(true)
  notes       String?
  recordedBy  String?
  createdAt   DateTime @default(now())
  santri      Santri   @relation("MutabaahToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId, date])
  @@map("mutabaah")
}

model Wallet {
  id           String              @id @default(uuid())
  tenantId     String
  santriId     String              @unique
  saldo        Decimal             @default(0) @db.Decimal(15, 2)
  // CHECK constraint saldo >= 0 enforced at DB level — Requirement 12.2
  balance      Float               @default(0)  // kept for backward compat
  pin          String?
  isActive     Boolean             @default(true)
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
  santri       Santri              @relation("WalletToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("wallets")
}

model WalletTransaction {
  id             String   @id @default(uuid())
  walletId       String
  tipe           String   @default("TOPUP")  // TOPUP, DEBIT, REFUND — Requirement 12.2
  jumlah         Decimal  @db.Decimal(15, 2)
  saldoSebelum   Decimal  @db.Decimal(15, 2)
  saldoSesudah   Decimal  @db.Decimal(15, 2)
  referensiId    String?  // invoice_id or koperasi_transaction_id
  keterangan     String?
  serverTimestamp DateTime @default(now())
  // Legacy fields kept for backward compat
  amount         Float    @default(0)
  type           String   @default("TOPUP")
  method         String   @default("MANUAL")
  description    String?
  reference      String?
  status         String   @default("SUCCESS")
  handledBy      String?
  createdAt      DateTime @default(now())
  createdBy      String?  // userId
  wallet         Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@map("wallet_transactions")
}

model Employee {
  id        String    @id @default(uuid())
  tenantId  String
  userId    String?   @unique
  nip       String?
  name      String
  position  String
  phone     String?
  address   String?
  joinDate  DateTime?
  status    String    @default("AKTIF")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrolls  Payroll[]

  @@index([tenantId])
  @@map("employees")
}

model Payroll {
  id         String    @id @default(uuid())
  tenantId   String
  employeeId String
  month      Int
  year       Int
  baseSalary Float     @default(0)
  allowances Float     @default(0)
  deductions Float     @default(0)
  netAmount  Float
  status     String    @default("DRAFT")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@map("payrolls")
}

model AcademicSchedule {
  id        String   @id @default(uuid())
  tenantId  String
  subject   String
  teacherId String
  kelas     String
  dayOfWeek Int
  startTime String
  endTime   String
  room      String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("academic_schedules")
}

model Attendance {
  id         String   @id @default(uuid())
  tenantId   String
  santriId   String
  scheduleId String?
  date       DateTime @default(now())
  status     String
  notes      String?
  recordedBy String?
  createdAt  DateTime @default(now())
  santri     Santri   @relation("AttendanceToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId, date])
  @@map("attendances")
}

model Grade {
  id           String   @id @default(uuid())
  tenantId     String
  santriId     String
  subject      String
  semester     String
  academicYear String
  type         String
  score        Float
  notes        String?
  createdAt    DateTime @default(now())
  santri       Santri   @relation("GradeToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("grades")
}

model PpdbRegistration {
  id                 String         @id @default(uuid())
  tenantId           String
  registrationNumber String         @unique
  fullName           String
  gender             String
  dob                DateTime?
  previousSchool     String?
  pathway            String         @default("REGULER")
  status             String         @default("PENDING")
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  documents          PpdbDocument[]
  exams              PpdbExam[]
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("ppdb_registrations")
}

model PpdbDocument {
  id             String           @id @default(uuid())
  tenantId       String
  registrationId String
  documentType   String
  fileUrl        String
  isVerified     Boolean          @default(false)
  createdAt      DateTime         @default(now())
  registration   PpdbRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("ppdb_documents")
}

model PpdbExam {
  id             String           @id @default(uuid())
  tenantId       String
  registrationId String
  examType       String
  examDate       DateTime
  score          Float?
  result         String?
  interviewer    String?
  createdAt      DateTime         @default(now())
  registration   PpdbRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@map("ppdb_exams")
}

model Item {
  id           String                 @id @default(uuid())
  tenantId     String
  sku          String                 @unique
  name         String
  description  String?
  category     String
  price        Float
  costPrice    Float?
  stock        Int                    @default(0)
  minStock     Int                    @default(5)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transactions InventoryTransaction[]
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("items")
}

model InventoryTransaction {
  id        String   @id @default(uuid())
  tenantId  String
  itemId    String
  type      String
  quantity  Int
  reference String?
  notes     String?
  handledBy String?
  date      DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([itemId])
  @@map("inventory_transactions")
}

model Supplier {
  id             String          @id @default(uuid())
  tenantId       String
  name           String
  contact        String?
  address        String?
  email          String?
  createdAt      DateTime        @default(now())
  purchaseOrders PurchaseOrder[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id         String   @id @default(uuid())
  tenantId   String
  supplierId String
  poNumber   String   @unique
  totalCost  Float
  status     String   @default("DRAFT")
  orderDate  DateTime @default(now())
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("purchase_orders")
}

model Building {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  gender      String
  capacity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms       Room[]

  @@index([tenantId])
  @@map("buildings")
}

model Room {
  id          String              @id @default(uuid())
  tenantId    String
  buildingId  String
  name        String
  capacity    Int
  picName     String?
  createdAt   DateTime            @default(now())
  tickets     MaintenanceTicket[]
  assignments RoomAssignment[]
  building    Building            @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([buildingId])
  @@map("rooms")
}

model RoomAssignment {
  id        String    @id @default(uuid())
  tenantId  String
  roomId    String
  santriId  String
  startDate DateTime  @default(now())
  endDate   DateTime?
  status    String    @default("ACTIVE")
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([roomId])
  @@map("room_assignments")
}

model MaintenanceTicket {
  id          String    @id @default(uuid())
  tenantId    String
  roomId      String
  title       String
  description String
  priority    String    @default("MEDIUM")
  status      String    @default("OPEN")
  reportedBy  String
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([roomId])
  @@map("maintenance_tickets")
}

model Point {
  id          String   @id @default(uuid())
  tenantId    String
  santriId    String
  category    String
  points      Int
  description String
  createdBy   String?
  createdAt   DateTime @default(now())
  santri      Santri   @relation("PointToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([santriId])
  @@map("points")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())

  @@map("roles")
}

model Permission {
  id       String  @id @default(uuid())
  roleId   String
  module   String
  canRead  Boolean @default(false)
  canWrite Boolean @default(false)
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@map("permissions")
}

model LoginAttempt {
  id          String   @id @default(uuid())
  ipAddress   String
  attemptedAt DateTime @default(now())
  success     Boolean  @default(false)

  @@index([ipAddress, attemptedAt])
  @@map("login_attempts")
}

model License {
  id                  String    @id @default(uuid())
  licenseKey          String    @unique
  hardwareFingerprint String?
  activatedAt         DateTime?
  lastVerifiedAt      DateTime?
  gracePeriodDays     Int       @default(30)
  status              String    @default("INACTIVE")
  metadata            Json?
  createdAt           DateTime  @default(now())

  @@map("license")
}

// ─── WhatsApp Queue Engine ────────────────────────────────────────────────────

model WaQueue {
  id               String    @id @default(uuid())
  tipeNotifikasi   String    // presensi, pembayaran, pelanggaran, reward, izin, kunjungan, buku_penghubung, topup
  noTujuan         String    // nomor WA tujuan
  templateKey      String    // key template yang digunakan
  payload          Json      // variabel untuk render template
  status           String    @default("PENDING") // PENDING, RETRYING, SENT, FAILED, DLQ
  retryCount       Int       @default(0)
  nextRetryAt      DateTime?
  sentAt           DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, nextRetryAt])
  @@map("wa_queue")
}

model WaTemplate {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. PRESENSI_MASUK, PEMBAYARAN_BERHASIL
  body      String   // template dengan variabel {{variable}}
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wa_templates")
}

// ─── Presensi (Attendance QR + GPS) ─────────────────────────────────────────

model PresensiSession {
  id            String            @id @default(uuid())
  tenantId      String
  namaSesi      String
  tipe          String            // MASUK, KELUAR, SHOLAT, dll
  qrToken       String?           @unique
  qrExpiresAt   DateTime?
  lokasiLat     Decimal?          @db.Decimal(10, 8)
  lokasiLng     Decimal?          @db.Decimal(11, 8)
  radiusMeter   Int               @default(100)
  createdBy     String
  createdAt     DateTime          @default(now())
  closedAt      DateTime?
  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  records       PresensiRecord[]

  @@index([tenantId])
  @@index([qrToken])
  @@map("presensi_sessions")
}

model PresensiRecord {
  id              String          @id @default(uuid())
  sessionId       String
  santriId        String
  status          String          // HADIR, PENDING_REVIEW, DITOLAK
  gpsLat          Decimal?        @db.Decimal(10, 8)
  gpsLng          Decimal?        @db.Decimal(11, 8)
  gpsAccuracy     Decimal?        @db.Decimal(8, 2)
  serverTimestamp DateTime        @default(now())
  clientTimestamp DateTime?
  faceVerified    Boolean         @default(false)
  session         PresensiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  santri          Santri          @relation("PresensiRecordToSantri", fields: [santriId], references: [id], onDelete: Cascade)

  @@unique([sessionId, santriId])  // idempotency — Requirement 5.8
  @@index([santriId])
  @@index([sessionId])
  @@map("presensi_records")
}

// ─── Perizinan (Leave Permits) ────────────────────────────────────────────────
// Status enum: DRAFT, SUBMITTED, APPROVED, REJECTED, COMPLETED, CANCELLED, TERLAMBAT
// State machine — Requirements: 14.1

model Perizinan {
  id             String    @id @default(uuid())
  tenantId       String
  santriId       String
  tipe           String    // PULANG, KELUAR_KOTA, LAINNYA
  alasan         String
  tanggalMulai   DateTime
  tanggalSelesai DateTime
  status         String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, COMPLETED, CANCELLED, TERLAMBAT
  approvedBy     String?   // FK → users (nullable)
  approvedAt     DateTime?
  kembaliAt      DateTime?
  terlambat      Boolean   @default(false)
  createdBy      String    // FK → users NOT NULL
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  santri         Santri    @relation("PerizinanToSantri", fields: [santriId], references: [id], onDelete: Cascade)
  tenant         Tenant    @relation("PerizinanToTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  approver       User?     @relation("PerizinanApprover", fields: [approvedBy], references: [id])
  creator        User      @relation("PerizinanCreator", fields: [createdBy], references: [id])

  @@index([tenantId])
  @@index([santriId])
  @@index([status])
  @@index([tanggalSelesai])
  @@map("perizinan")
}

// ─── Pelanggaran & Reward Poin ────────────────────────────────────────────────

enum TingkatKeparahan {
  RINGAN
  SEDANG
  BERAT
}

model KategoriPelanggaran {
  id               String           @id @default(uuid())
  nama             String           @unique
  deskripsi        String?
  tingkatKeparahan TingkatKeparahan
  poinDefault      Int              @default(0)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  pelanggaran      Pelanggaran[]

  @@map("kategori_pelanggaran")
}

model RewardPoin {
  id              String   @id @default(uuid())
  santriId        String
  poin            Int
  keterangan      String
  serverTimestamp DateTime @default(now())
  createdBy       String
  createdAt       DateTime @default(now())
  santri          Santri   @relation(fields: [santriId], references: [id], onDelete: Cascade)
  creator         User     @relation("RewardPoinCreatedBy", fields: [createdBy], references: [id])

  @@index([santriId])
  @@map("reward_poin")
}
